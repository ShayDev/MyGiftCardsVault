generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum TransactionType {
  RECHARGE
  SPEND
}

model FamilyGroup {
  id          String        @id @default(uuid())
  name        String        // stored uppercase e.g. "THE SMITHS"
  inviteCode  String        @unique
  users       User[]
  giftCards   GiftCard[]
  vouchers    Voucher[]
  clubMembers ClubMember[]
  refunds     Refund[]
  createdAt   DateTime      @default(now())
}

model User {
  id         String      @id @default(uuid())
  clerkId    String      @unique
  email      String      @unique
  name       String?
  role       String      @default("member")
  familyId   String?
  family     FamilyGroup? @relation(fields: [familyId], references: [id])
  createdAt  DateTime    @default(now())
}

model GiftCard {
  id           String        @id @default(uuid())
  seq          Int           @default(autoincrement())
  familyId     String
  family       FamilyGroup   @relation(fields: [familyId], references: [id])
  name         String
  provider     String
  last4        String?       // last 4 digits, required unless link provided
  fullNumber   String?       // full card number, optional
  cvv          String?       // CVV/CVC, optional
  link         String?       // one-time URL (dynamic code via link)
  expiresAt    String?       // expiration as MMYY, e.g. "1228"
  notes        String?       // card notes, optional
  isReloadable Boolean       @default(true)
  isActive     Boolean       @default(true)
  metadata     Json?
  transactions Transaction[]
  createdBy    String?
  createdAt    DateTime      @default(now())
}

model Transaction {
  id         String          @id @default(uuid())
  giftCardId String
  giftCard   GiftCard        @relation(fields: [giftCardId], references: [id])
  type       TransactionType
  // Positive decimal amount. Interpretation: RECHARGE adds, SPEND subtracts.
  amount     Decimal         @db.Decimal(65, 30)
  notes      String?
  createdBy  String?
  createdAt  DateTime        @default(now())
}

model ClubMember {
  id          String      @id @default(uuid())
  seq         Int         @default(autoincrement())
  familyId    String
  family      FamilyGroup @relation(fields: [familyId], references: [id])
  name        String
  provider    String
  memberId    String?
  ownerName   String?
  idType      String?
  expiresAt   String?
  notes       String?
  isActive    Boolean     @default(true)
  createdBy   String?
  createdAt   DateTime    @default(now())
}

model Refund {
  id          String    @id @default(uuid())
  seq         Int       @default(autoincrement())
  familyId    String
  family      FamilyGroup @relation(fields: [familyId], references: [id])
  provider    String
  amount      Decimal   @db.Decimal(65, 30)
  currency    String
  status      String    @default("pending")
  referenceId String?
  notes       String?
  expiresAt   String?
  receivedAt  DateTime?
  code        String?
  link        String?
  imageUrl    String?
  usedAmount  Decimal   @default(0) @db.Decimal(65, 30)
  isUsed      Boolean   @default(false)
  usedAt      DateTime?
  isActive    Boolean   @default(true)
  createdBy   String?
  createdAt   DateTime  @default(now())
}

model Voucher {
  id          String      @id @default(uuid())
  seq         Int         @default(autoincrement())
  familyId    String
  family      FamilyGroup @relation(fields: [familyId], references: [id])
  name        String
  provider    String
  code        String?
  link        String?
  value       Decimal?    @db.Decimal(65, 30)
  expiresAt   String?
  notes       String?
  isUsed      Boolean     @default(false)
  usedAt      DateTime?
  usedBy      String?
  isActive    Boolean     @default(true)
  createdBy   String?
  createdAt   DateTime    @default(now())
}
